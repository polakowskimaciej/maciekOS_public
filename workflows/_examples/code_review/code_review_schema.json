{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["summary", "issues", "approval"],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["data", "message", "suggestion"],
        "additionalProperties": false,
        "properties": {
          "data": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "string",
      "enum": ["approved", "changes_requested", "needs_discussion"]
    }
  }
}
